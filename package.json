{
  "name": "fluxpoint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:production": "bash scripts/build-production.sh",
    "deploy:local": "bash scripts/deploy-local.sh",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
