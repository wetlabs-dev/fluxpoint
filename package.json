{
  "name": "fluxpoint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx scripts/bootstrap.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:bootstrap": "tsx scripts/bootstrap.ts",
    "docker:build": "docker compose build",
    "docker:build:app": "docker compose build app",
    "docker:build:workers": "docker compose build migrate",
    "docker:build:prod": "docker compose build app migrate",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "worker:reminders": "tsx scripts/workers/reminders.ts",
    "worker:metrics": "tsx scripts/workers/metrics.ts",
    "worker:backups": "tsx scripts/workers/backups.ts",
    "worker:ai": "tsx scripts/workers/ai-worker.ts",
    "check": "npm run typecheck && npm run build",
    "check:production": "npm run typecheck && npm run db:generate && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@types/nodemailer": "^8.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "nodemailer": "^9.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx scripts/bootstrap.ts"
  }
}
