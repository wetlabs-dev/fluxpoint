fluxpoint.wetlabs.dev {
    encode zstd gzip
    reverse_proxy app:3000
}

www.wetlabs.dev {
    encode zstd gzip

    handle /fluxpoint* {
        reverse_proxy app:3000
    }

    handle /_next* {
        reverse_proxy app:3000
    }

    # The /fluxpoint marketing page uses the same shared brand components as the app.
    # Their root-relative image URLs must cross the www marketing proxy boundary too.
    handle /brand/* {
        reverse_proxy app:3000
    }

    handle /favicon.ico {
        reverse_proxy app:3000
    }

    # Existing www.wetlabs.dev handlers may go here.
}

# If the www.wetlabs.dev marketing site is served by another container mounted at its own root:
# Replace the active www.wetlabs.dev block above with this pattern:
# www.wetlabs.dev {
#     handle_path /fluxpoint* {
#         reverse_proxy wetlabs-site:3000
#     }
# }
