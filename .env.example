NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

NEXT_PUBLIC_APP_URL=https://fluxpoint.wetlabs.dev
NEXT_PUBLIC_MARKETING_URL=https://www.wetlabs.dev/fluxpoint
NEXT_PUBLIC_SITE_NAME=Fluxpoint
NEXT_PUBLIC_DONATE_URL=https://ko-fi.com/wetlabs
NEXT_PUBLIC_GITHUB_URL=https://github.com/wetlabs-dev/fluxpoint
NEXTAUTH_URL=https://fluxpoint.wetlabs.dev
AUTH_SECRET=change_me_to_a_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_deploying

POSTGRES_DB=fluxpoint
POSTGRES_USER=fluxpoint
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql://fluxpoint:change_me@localhost:5432/fluxpoint?schema=public

ENABLE_REMINDERS_WORKER=false
ENABLE_METRICS_WORKER=false
ENABLE_BACKUPS_WORKER=false
ENABLE_AI_WORKER=false

METRICS_ENABLED=true
METRICS_BACKEND=prometheus
GRAPH_BACKEND=grafana
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=30d
GRAFANA_URL=http://grafana:3000
GRAFANA_PUBLIC_URL=
GRAFANA_EMBED_MODE=native
GRAFANA_ADMIN_USER=fluxpoint
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_SERVICE_ACCOUNT_TOKEN=
GRAFANA_ALLOW_EMBEDDING=true
GRAFANA_ANONYMOUS_ENABLED=false
GF_SECURITY_ADMIN_USER=fluxpoint
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SECURITY_ALLOW_EMBEDDING=true
GF_AUTH_ANONYMOUS_ENABLED=false

AI_ENABLED=true
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_DEFAULT_RESPONSES_MODEL=gpt-4.1-mini
OPENAI_DEFAULT_CHAT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MODERATION_MODEL=omni-moderation-latest

EMAIL_ENABLED=false
EMAIL_PROVIDER=console
EMAIL_DELIVERY_MODE=log
APP_EMAIL_FROM="Fluxpoint <no-reply@wetlabs.dev>"
SMTP_FROM="Fluxpoint <no-reply@wetlabs.dev>"
SMTP_REPLY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_NAME=Fluxpoint
SES_FROM_EMAIL=no-reply@wetlabs.dev
SES_REPLY_TO_EMAIL=
