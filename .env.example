NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

NEXT_PUBLIC_APP_URL=https://fluxpoint.wetlabs.dev
NEXT_PUBLIC_MARKETING_URL=https://www.wetlabs.dev/fluxpoint
NEXT_PUBLIC_SITE_NAME=Fluxpoint
NEXT_PUBLIC_DONATE_URL=https://ko-fi.com/wetlabs
NEXT_PUBLIC_GITHUB_URL=https://github.com/wetlabs-dev/fluxpoint
NEXTAUTH_URL=https://fluxpoint.wetlabs.dev
AUTH_SECRET=change_me_to_a_long_random_secret
TOTP_ENCRYPTION_KEY=change_me_to_a_different_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_deploying

POSTGRES_DB=fluxpoint
POSTGRES_USER=fluxpoint
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql://fluxpoint:change_me@localhost:5432/fluxpoint?schema=public

ENABLE_REMINDERS_WORKER=false
REMINDER_WORKER_INTERVAL_MS=300000
ENABLE_METRICS_WORKER=false
ENABLE_BACKUPS_WORKER=false
ENABLE_AI_WORKER=false
AI_WORKER_INTERVAL_SECONDS=15
AI_WORKER_BATCH_SIZE=2
AI_JOB_STALE_CLAIM_MINUTES=20
AI_JOB_MAX_ATTEMPTS=3
ENABLE_IMAGE_MODERATION_WORKER=false
ENABLE_INTELLIGENCE_WORKER=false

METRICS_ENABLED=true
METRICS_BACKEND=prometheus
GRAPH_BACKEND=grafana
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=30d
GRAFANA_URL=http://grafana:3000
GRAFANA_PUBLIC_URL=
GRAFANA_EMBED_MODE=native
GRAFANA_ADMIN_USER=fluxpoint
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_SERVICE_ACCOUNT_TOKEN=
GRAFANA_ALLOW_EMBEDDING=true
GRAFANA_ANONYMOUS_ENABLED=false
GF_SECURITY_ADMIN_USER=fluxpoint
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SECURITY_ALLOW_EMBEDDING=true
GF_AUTH_ANONYMOUS_ENABLED=false

AI_ENABLED=true
AI_PROVIDER=mock
AI_IMAGE_ENABLED=true
AI_MODERATION_ENABLED=true
AI_RATE_LIMITS_ENABLED=true
EDDY_DAILY_USER_LIMIT_DEFAULT=20
EDDY_DAILY_COLLECTION_LIMIT_DEFAULT=100
EDDY_MONTHLY_COLLECTION_LIMIT_DEFAULT=1000
EDDY_IMAGE_DAILY_USER_LIMIT=3
EDDY_IMAGE_DAILY_COLLECTION_LIMIT=10
EDDY_HUSBANDRY_DAILY_USER_LIMIT=10
EDDY_STOCKING_PRESSURE_DAILY_USER_LIMIT=6
OPENAI_API_KEY=
OPENAI_DEFAULT_RESPONSES_MODEL=gpt-4.1-mini
OPENAI_DEFAULT_CHAT_MODEL=gpt-4.1-mini
OPENAI_COVER_IMAGE_MODEL=gpt-image-1-mini
OPENAI_COVER_IMAGE_SIZE=1024x1024
OPENAI_COVER_IMAGE_QUALITY=low
OPENAI_IMAGE_MODEL=
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_IMAGE_MODERATION_MODEL=omni-moderation-latest
OPENAI_AQUARIUM_IMAGE_CHECK_MODEL=gpt-4.1-mini
FLUXPOINT_IMAGE_MODERATION_ENABLED=true
IMAGE_MODERATION_ENABLED=true
IMAGE_MODERATION_PROVIDER=openai
IMAGE_MODERATION_FAIL_CLOSED=true
IMAGE_MODERATION_DEV_BYPASS=false
FLUXPOINT_IMAGE_MODERATION_WORKER_INTERVAL_SECONDS=180
IMAGE_MODERATION_WORKER_INTERVAL_SECONDS=180
FLUXPOINT_IMAGE_MODERATION_BATCH_SIZE=10
IMAGE_MODERATION_BATCH_SIZE=10
MEDIA_UPLOAD_MAX_BYTES=12582912
SERVER_METRICS_ENABLED=true
SERVER_METRICS_RETENTION_HOURS=48
METRICS_WORKER_INTERVAL_MS=300000
BACKUP_WORKER_INTERVAL_SECONDS=60
INTELLIGENCE_WORKER_INTERVAL_MS=3600000
BACKUP_RETENTION_DAYS=180

EMAIL_ENABLED=false
EMAIL_PROVIDER=console
EMAIL_DELIVERY_MODE=log
APP_EMAIL_FROM="Fluxpoint <no-reply@wetlabs.dev>"
SMTP_FROM="Fluxpoint <no-reply@wetlabs.dev>"
SMTP_REPLY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_NAME=Fluxpoint
SES_FROM_EMAIL=no-reply@wetlabs.dev
SES_REPLY_TO_EMAIL=

NEXT_PUBLIC_ENABLE_WEB_PUSH=false
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@wetlabs.dev

# Optional docs screenshot runner overrides. Prefer a dedicated docs account
# with only the privileges needed for manual screenshots.
FLUXPOINT_DOCS_EMAIL=
FLUXPOINT_DOCS_PASSWORD=
FLUXPOINT_DOCS_TOTP_CODE=
FLUXPOINT_DOCS_TOTP_SECRET=
FLUXPOINT_DOCS_SKIP_LOGIN=false
