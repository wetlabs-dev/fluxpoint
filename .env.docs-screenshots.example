# Optional overrides for `docker compose --profile docs run --rm docs`.
#
# The docs runner reads `.env.production` first and can fall back to
# ADMIN_EMAIL / ADMIN_PASSWORD. Use this file only when you want screenshots
# captured with a different account, target, or 2FA setup.
#
# To use:
#   cp .env.docs-screenshots.example .env.docs-screenshots
#   nano .env.docs-screenshots

# Inside Docker Compose, the default target is the app service.
FLUXPOINT_DOCS_BASE_URL=http://app:3000

# Optional dedicated screenshot account. If omitted, ADMIN_EMAIL and
# ADMIN_PASSWORD from .env.production are used.
FLUXPOINT_DOCS_EMAIL=
FLUXPOINT_DOCS_PASSWORD=

# If the account has TOTP enabled, provide either one current code or the
# base32 secret so the script can generate a current code.
FLUXPOINT_DOCS_TOTP_CODE=
FLUXPOINT_DOCS_TOTP_SECRET=

# Only use this for public/manual-friendly targets that do not require login.
FLUXPOINT_DOCS_SKIP_LOGIN=false
