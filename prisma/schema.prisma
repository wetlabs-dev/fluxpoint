model MediaAsset {
  id                    String                  @id @default(cuid())
  collectionId          String
  collection            Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId            String?
  aquarium              Aquarium?               @relation("AquariumMedia", fields: [aquariumId], references: [id], onDelete: Cascade)
  itemId                String?
  item                  AquariumItem?           @relation(fields: [itemId], references: [id], onDelete: SetNull)
  speciesDefinitionId   String?
  speciesDefinition     SpeciesDefinition?      @relation(fields: [speciesDefinitionId], references: [id], onDelete: SetNull)
  aquariumEventId       String?
  aquariumEvent         AquariumEvent?          @relation(fields: [aquariumEventId], references: [id], onDelete: SetNull)
  conditionId           String?
  condition             HealthCondition?        @relation(fields: [conditionId], references: [id], onDelete: SetNull)
  uploadedById          String?
  uploadedBy            User?                   @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  coverForAquarium      Aquarium?               @relation("AquariumCoverMedia")
  filename              String
  originalFilename      String
  mimeType              String
  sizeBytes             Int
  width                 Int?
  height                Int?
  url                   String
  thumbnailUrl          String?
  caption               String?
  altText               String?
  moderationStatus      MediaModerationStatus   @default(PENDING)
  moderationReason      String?
  moderationModel       String?
  moderationCheckedAt   DateTime?
  moderationAttempts    Int                     @default(0)
  moderationLastError   String?
  visibility            MediaVisibility         @default(COLLECTION)
  hiddenAt              DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([collectionId, createdAt])
  @@index([aquariumId, createdAt])
  @@index([itemId])
  @@index([aquariumEventId])
  @@index([conditionId, createdAt])
  @@index([moderationStatus, moderationAttempts, createdAt])
  @@index([visibility, moderationStatus])
}

model HealthCondition {
  id                 String                      @id @default(cuid())
  collectionId       String
  collection         Collection                  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId         String?
  aquarium           Aquarium?                   @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  entityType         HealthConditionEntityType
  entityId           String?
  title              String
  conditionType      String
  category           HealthConditionCategory
  status             HealthConditionStatus       @default(ACTIVE)
  severity           HealthConditionSeverity     @default(MODERATE)
  firstObservedAt    DateTime
  lastObservedAt     DateTime?
  resolvedAt         DateTime?
  affectedCount      Float?
  affectedCountLabel String?
  summary            String?
  suspectedCause     String?
  actionPlan         String?
  resolutionNotes    String?
  createdById        String?
  createdBy          User?                       @relation("HealthConditionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById        String?
  updatedBy          User?                       @relation("HealthConditionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  observations       HealthConditionObservation[]
  links              HealthConditionLink[]
  careTasks          CareTask[]
  medicationCourses  MedicationCourse[]
  aquariumEvents     AquariumEvent[]
  mediaAssets        MediaAsset[]
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([collectionId, status, severity])
  @@index([aquariumId, status])
  @@index([entityType, entityId, status])
  @@index([lastObservedAt])
}

model HealthConditionObservation {
  id            String                   @id @default(cuid())
  collectionId  String
  collection    Collection               @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  conditionId   String
  condition     HealthCondition          @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  observedAt    DateTime
  status        HealthConditionStatus?
  severity      HealthConditionSeverity?
  affectedCount Float?
  notes         String
  createdById   String?
  createdBy     User?                    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime                 @default(now())

  @@index([conditionId, observedAt])
  @@index([collectionId, createdAt])
}

model HealthConditionLink {
  id               String                          @id @default(cuid())
  collectionId     String
  collection       Collection                      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  conditionId      String
  condition        HealthCondition                 @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  linkedEntityType HealthConditionLinkedEntityType
  linkedEntityId   String
  relationship     HealthConditionRelationship
  createdAt        DateTime                        @default(now())

  @@unique([conditionId, linkedEntityType, linkedEntityId, relationship])
  @@index([collectionId, linkedEntityType, linkedEntityId])
}

model ServerMetricSnapshot {
