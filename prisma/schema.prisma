model User {
  id                               String                             @id @default(cuid())
  name                             String
  email                            String                             @unique
  passwordHash                     String?
  serverRole                       ServerRole                         @default(STANDARD_USER)
  timezone                         String                             @default("America/New_York")
  sessions                         Session[]
  twoFactor                        UserTwoFactor?
  twoFactorChallenges              TwoFactorChallenge[]
  collections                      Collection[]
  collectionMemberships            CollectionMembership[]
  transfers                        ItemTransfer[]
  events                           AquariumEvent[]
  completedCareTasks               CareTask[]                         @relation("CareTaskCompletedBy")
  aiRequestLogs                    AiRequestLog[]
  stockingPressureEstimates        AquariumStockingPressureEstimate[]
  regionalStatusChecks             SpeciesRegionalStatus[]            @relation("RegionalStatusCheckedBy")
  aiRateLimitUsages                AiRateLimitUsage[]
  aiRateLimitOverrides             AiRateLimitOverride[]
  moderationReviews                ModerationReview[]
  imageModerationReviews           ImageModerationReview[]            @relation("ImageModerationReviewUploader")
  resolvedImageModerationReviews   ImageModerationReview[]            @relation("ImageModerationReviewResolver")
  mediaAssets                      MediaAsset[]                       @relation("MediaUploader")
  emailLogs                        EmailLog[]
  notificationPreference           NotificationPreference?
  pushSubscriptions                PushSubscription[]
  notificationDeliveries           NotificationDelivery[]
  createdWorkflowTemplates         WorkflowTemplate[]                 @relation("WorkflowTemplateCreatedBy")
  startedWorkflowRuns              WorkflowRun[]                      @relation("WorkflowRunStartedBy")
  completedWorkflowStepRuns        WorkflowStepRun[]                  @relation("WorkflowStepRunCompletedBy")
  passwordResetTokens              PasswordResetToken[]
  sentInvitations                  CollectionInvitation[]             @relation("InvitationInviter")
  reviewedAccountRequests          AccountRequest[]                   @relation("AccountRequestReviewer")
  invitedAccountRequests           AccountRequest[]                   @relation("AccountRequestInvitedUser")
  auditLogs                        AuditLog[]
  openedTankAudits                 TankAuditSession[]                 @relation("TankAuditOpenedBy")
  finalizedTankAudits              TankAuditSession[]                 @relation("TankAuditFinalizedBy")
  cancelledTankAudits              TankAuditSession[]                 @relation("TankAuditCancelledBy")
  createdBreedingProjects          BreedingProject[]                  @relation("BreedingProjectCreatedBy")
  completedBreedingProjects        BreedingProject[]                  @relation("BreedingProjectCompletedBy")
  breedingObservations             BreedingObservation[]
  breedingSummaries                BreedingSummary[]                  @relation("BreedingSummaryGeneratedBy")
  generatedLabels                  GeneratedLabel[]
  createdEmergencyPlans            EmergencyPlan[]                    @relation("EmergencyPlanCreatedBy")
  createdEmergencyIncidents        EmergencyIncident[]                @relation("EmergencyIncidentCreatedBy")
  completedEmergencySteps          EmergencyIncidentStep[]            @relation("EmergencyStepCompletedBy")
  emergencyIncidentLogs            EmergencyIncidentLog[]             @relation("EmergencyLogCreatedBy")
  createdAquariumPlans             AquariumPlan[]                     @relation("AquariumPlanCreatedBy")
  completedAquariumPlans           AquariumPlan[]                     @relation("AquariumPlanCompletedBy")
  implementedAquariumPlanItems     AquariumPlanItem[]                 @relation("AquariumPlanItemImplementedBy")
  requestedHealthAssessments       AquariumHealthAssessment[]         @relation("AquariumHealthAssessmentRequestedBy")
  createdHealthConditions          HealthCondition[]                  @relation("HealthConditionCreatedBy")
  updatedHealthConditions          HealthCondition[]                  @relation("HealthConditionUpdatedBy")
  healthConditionObservations      HealthConditionObservation[]
  serverIncidents                  ServerIncident[]                   @relation("ServerIncidentCreator")
  updatedServerMaintenanceSettings ServerMaintenanceSettings[]        @relation("ServerMaintenanceSettingsUpdatedBy")
  backupRequests                   BackupRequest[]                    @relation("BackupRequester")
  restorePlans                     RestorePlan[]                      @relation("RestorePlanRequester")
  maintenanceStarts                MaintenanceMode[]                  @relation("MaintenanceStartedBy")
  maintenanceEnds                  MaintenanceMode[]                  @relation("MaintenanceEndedBy")
  createdAt                        DateTime                           @default(now())
  updatedAt                        DateTime                           @updatedAt
  lastLoginAt                      DateTime?
  disabledAt                       DateTime?
}

model Session {
  id                  String    @id @default(cuid())
  tokenHash           String    @unique
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  twoFactorVerifiedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UserTwoFactor {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  secretCiphertext         String
  recoveryCodesCiphertext  String?
  recoveryCodesGeneratedAt DateTime?
  recoveryCodesViewedAt    DateTime?
  enabledAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recoveryCodes TwoFactorRecoveryCode[]
}

model TwoFactorChallenge {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model TwoFactorRecoveryCode {
  id              String    @id @default(cuid())
  userTwoFactorId String
  codeHash        String
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  userTwoFactor UserTwoFactor @relation(fields: [userTwoFactorId], references: [id], onDelete: Cascade)

  @@unique([userTwoFactorId, codeHash])
  @@index([userTwoFactorId])
  @@index([usedAt])
}

model Collection {
  id                           String                             @id @default(cuid())
  name                         String
  description                  String?
  localityCity                 String?
  localityRegion               String?
  localityCountry              String?
  localityPostalCode           String?
  localityLabel                String?
  localityNotes                String?
  ownerId                      String
  owner                        User                               @relation(fields: [ownerId], references: [id])
  aquariums                    Aquarium[]
  aquariumEquipmentAttachments AquariumEquipmentAttachment[]
  items                        AquariumItem[]
  locations                    Location[]
  sources                      Source[]
  waterSources                 WaterSource[]
  waterRecipes                 WaterRecipe[]
  waterRecipeAdditives         WaterRecipeAdditive[]
  lightCapabilityProfiles      LightCapabilityProfile[]
  lightingSchedules            LightingSchedule[]
