  incident     EmergencyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  aquariumId   String?
  aquarium     Aquarium?         @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  loggedAt     DateTime          @default(now())
  logType      EmergencyLogType  @default(NOTE)
  message      String
  metadata     Json?
  createdById  String?
  createdBy    User?             @relation("EmergencyLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())

  @@index([collectionId, incidentId, loggedAt])
  @@index([aquariumId, loggedAt])
  @@index([logType, loggedAt])
  @@index([createdById])
}

model AuditLog {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  actorUserId      String?
  actor            User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail       String?
  actorDisplayName String?
  actorRole        String?
  collectionId     String?
  collection       Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  entityType       String
  entityId         String?
  action           String
  summary          String
  details          Json?
  metadata         Json?
  before           Json?
  after            Json?
  ipAddress        String?
  userAgent        String?
  requestId        String?
  severity         AuditSeverity @default(INFO)
  scope            AuditScope    @default(SYSTEM)

  @@index([createdAt])
  @@index([collectionId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([severity, createdAt])
  @@index([scope, createdAt])
}
