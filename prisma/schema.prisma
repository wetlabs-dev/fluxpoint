generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TankType {
  FRESHWATER
  BRACKISH
  SALTWATER
  POND
  QUARANTINE
  GROWOUT
  OTHER
}

enum AquariumStatus {
  ACTIVE
  PLANNING
  ARCHIVED
}

enum SpeciesCategory {
  FISH
  INVERT
  PLANT
  CORAL
  OTHER
}

enum ItemType {
  FISH
  INVERT
  PLANT
  SUBSTRATE
  HARDSCAPE
  EQUIPMENT
  BOTANICAL
  FOOD
  MEDICATION
  ADDITIVE
  OTHER
}

enum AquariumItemStatus {
  ACTIVE
  ARCHIVED
  CONSUMED
  DEAD
  REMOVED
  TRANSFERRED
}

enum EquipmentType {
  HEATER
  LIGHT
  FILTER
  PUMP
  AIR_PUMP
  CO2
  SENSOR
  CONTROLLER
  DOSER
  OTHER
}

enum AquariumEventType {
  NOTE
  FEEDING
  WATER_CHANGE
  TEST_RESULT
  MAINTENANCE
  MEDICATION
  STOCKING
  DEATH
  SPAWN
  PHOTO
  EQUIPMENT_CHANGE
  TRANSFER
  AUDIT
  OTHER
}

enum WaterParameter {
  TEMPERATURE
  PH
  CO2
  AMMONIA
  NITRITE
  NITRATE
  GH
  KH
  TDS
  TURBIDITY
  LIGHT
  WATER_LEVEL
  OTHER
}

enum ReadingSource {
  MANUAL
  SENSOR
  PROMETHEUS
  IMPORTED
}

enum SensorDeviceType {
  RASPBERRY_PI
  PICO
  ESP32
  MANUAL
  OTHER
}

enum SensorStatus {
  ACTIVE
  INACTIVE
  ERROR
  RETIRED
}

enum WorkflowCategory {
  MAINTENANCE
  QUARANTINE
  MEDICATION
  BREEDING
  CYCLING
  ACCLIMATION
  VACATION
  CUSTOM
}

enum WorkflowStepType {
  TASK
  CHECK
  INPUT
  DECISION
  WAIT
  LOG_EVENT
}

enum WorkflowRunStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

enum WorkflowStepRunStatus {
  PENDING
  COMPLETED
  SKIPPED
  BLOCKED
}

enum AiSuggestionType {
  TANK_NAME
  COVER_CARD
  CARE_ADVICE
  WORKFLOW
  STOCKING
  OTHER
}

enum LocationType {
  ROOM
  RACK
  SHELF
  STAND
  CABINET
  OUTDOOR_AREA
  OTHER
}

enum SourceType {
  STORE
  ONLINE_VENDOR
  BREEDER
  LOCAL_CLUB
  FRIEND
  IMPORTER
  SELF_PROPAGATED
  OTHER
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  passwordHash  String?
  sessions      Session[]
  collections   Collection[]
  transfers     ItemTransfer[]
  events        AquariumEvent[]
  auditLogs     AuditLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id])
  aquariums   Aquarium[]
  items       AquariumItem[]
  locations   Location[]
  sources     Source[]
  lightingSchedules LightingSchedule[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Location {
  id          String      @id @default(cuid())
  collectionId String
  collection  Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Location?   @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Location[]  @relation("LocationHierarchy")
  name        String
  type        LocationType @default(OTHER)
  description String?
  sortOrder   Int         @default(0)
  aquariums   Aquarium[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Source {
  id          String     @id @default(cuid())
  collectionId String
  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name        String
  type        SourceType @default(OTHER)
  website     String?
  notes       String?
  items       AquariumItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Aquarium {
  id                   String                  @id @default(cuid())
  collectionId         String
  collection           Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name                 String
  generatedName        String?
  slug                 String                  @unique
  description          String?
  tankType             TankType
  volumeGallons        Float?
  lengthInches         Float?
  widthInches          Float?
  heightInches         Float?
  location             String?
  locationId           String?
  structuredLocation   Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status               AquariumStatus          @default(ACTIVE)
  startedAt            DateTime?
  notes                String?
  coverImageUrl        String?
  coverCardStyle       Json?
  profile              AquariumProfile?
  items                AquariumItem[]
  transfersFrom        ItemTransfer[]          @relation("TransferFromAquarium")
  transfersTo          ItemTransfer[]          @relation("TransferToAquarium")
  events               AquariumEvent[]
  readings             WaterParameterReading[]
  sensorDevices        SensorDevice[]
  workflowRuns         WorkflowRun[]
  aiSuggestions        AiSuggestion[]
  lightingAssignments  AquariumLightingAssignment[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
}

model AquariumProfile {
  id                String    @id @default(cuid())
  aquariumId        String    @unique
  aquarium          Aquarium  @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  substrate         String?
  lightingType      String?
  lightingSchedule  String?
  filtration        String?
  heating           String?
  co2               String?
  waterSource       String?
  targetTemperature Float?
  targetPh          Float?
  targetGh          Float?
  targetKh          Float?
  substrateItemId   String?
  substrateItem     AquariumItem? @relation("ProfileSubstrate", fields: [substrateItemId], references: [id], onDelete: SetNull)
  lightItemId       String?
  lightItem         AquariumItem? @relation("ProfileLight", fields: [lightItemId], references: [id], onDelete: SetNull)
  notes             String?
}

model SpeciesDefinition {
  id             String          @id @default(cuid())
  category       SpeciesCategory
  commonName     String
  scientificName String?
  genus          String?
  species        String?
  variety        String?
  cultivar       String?
  notes          String?
  careNotes      String?
  tempMin        Float?
  tempMax        Float?
  phMin          Float?
  phMax          Float?
  ghMin          Float?
  ghMax          Float?
  khMin          Float?
  khMax          Float?
  items          AquariumItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AquariumItem {
  id                  String              @id @default(cuid())
  aquariumId          String?
  aquarium            Aquarium?           @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  collectionId        String
  collection          Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  itemType            ItemType
  speciesDefinitionId String?
  speciesDefinition   SpeciesDefinition?  @relation(fields: [speciesDefinitionId], references: [id], onDelete: SetNull)
  name                String
  description         String?
  quantity            Float               @default(1)
  unit                String?
  status              AquariumItemStatus  @default(ACTIVE)
  acquiredFrom        String?
  sourceId            String?
  source              Source?             @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  purchasePrice       Decimal?            @db.Decimal(10, 2)
  acquiredAt          DateTime?
  notes               String?
  transfers           ItemTransfer[]
  equipmentProfile    EquipmentProfile?
  substrateProfiles   AquariumProfile[]   @relation("ProfileSubstrate")
  lightProfiles       AquariumProfile[]   @relation("ProfileLight")
  relatedEvents        AquariumEvent[]     @relation("EventRelatedItem")
  lightingAssignments  AquariumLightingAssignment[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model ItemTransfer {
  id             String     @id @default(cuid())
  itemId         String
  item           AquariumItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromAquariumId String?
  fromAquarium   Aquarium?  @relation("TransferFromAquarium", fields: [fromAquariumId], references: [id], onDelete: SetNull)
  toAquariumId   String?
  toAquarium     Aquarium?  @relation("TransferToAquarium", fields: [toAquariumId], references: [id], onDelete: SetNull)
  quantity       Float
  transferredAt  DateTime   @default(now())
  reason         String?
  notes          String?
  createdById    String?
  createdBy      User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model EquipmentProfile {
  id                      String        @id @default(cuid())
  itemId                  String        @unique
  item                    AquariumItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  equipmentType           EquipmentType
  brand                   String?
  model                   String?
  serialNumber            String?
  purchaseDate            DateTime?
  warrantyUntil           DateTime?
  maintenanceIntervalDays Int?
  lastMaintainedAt        DateTime?
  notes                   String?
}

model AquariumEvent {
  id          String            @id @default(cuid())
  aquariumId  String
  aquarium    Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  relatedItemId String?
  relatedItem   AquariumItem?    @relation("EventRelatedItem", fields: [relatedItemId], references: [id], onDelete: SetNull)
  eventType   AquariumEventType
  title       String
  summary     String?
  notes       String?
  maintenanceType String?
  waterChangePercent Float?
  waterChangeGallons Float?
  eventDate   DateTime          @default(now())
  createdById String?
  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([relatedItemId])
}

model WaterParameterReading {
  id          String          @id @default(cuid())
  aquariumId  String
  aquarium    Aquarium        @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  parameter   WaterParameter
  value       Float
  unit        String
  source      ReadingSource   @default(MANUAL)
  measuredAt  DateTime        @default(now())
  notes       String?
}

model LightingSchedule {
  id          String                  @id @default(cuid())
  collectionId String
  collection  Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name        String
  description String?
  points      LightingSchedulePoint[]
  assignments AquariumLightingAssignment[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([collectionId, name])
}

model LightingSchedulePoint {
  id          String           @id @default(cuid())
  scheduleId  String
  schedule    LightingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  timeOfDay   String
  white       Int
  red         Int
  green       Int
  blue        Int
  warmWhite   Int?
  intensity   Int?
  sortOrder   Int              @default(0)

  @@index([scheduleId, sortOrder])
}

model AquariumLightingAssignment {
  id              String            @id @default(cuid())
  aquariumId      String            @unique
  aquarium        Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  equipmentItemId String?
  equipmentItem   AquariumItem?     @relation(fields: [equipmentItemId], references: [id], onDelete: SetNull)
  scheduleId      String?
  schedule        LightingSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([equipmentItemId])
  @@index([scheduleId])
}

model SensorDevice {
  id             String            @id @default(cuid())
  aquariumId     String?
  aquarium       Aquarium?         @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  name           String
  deviceType     SensorDeviceType
  status         SensorStatus       @default(ACTIVE)
  prometheusJob  String?
  notes          String?
  channels       SensorChannel[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model SensorChannel {
  id                   String          @id @default(cuid())
  sensorDeviceId       String
  sensorDevice         SensorDevice    @relation(fields: [sensorDeviceId], references: [id], onDelete: Cascade)
  parameter            WaterParameter
  displayName          String
  unit                 String
  prometheusMetricName String?
  enabled              Boolean         @default(true)
}

model WorkflowTemplate {
  id          String             @id @default(cuid())
  name        String
  description String?
  category    WorkflowCategory
  isSystem    Boolean            @default(false)
  steps       WorkflowStep[]
  runs        WorkflowRun[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model WorkflowStep {
  id                 String           @id @default(cuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  title              String
  description        String?
  stepType           WorkflowStepType
  config             Json?
  runs               WorkflowStepRun[]
}

model WorkflowRun {
  id                 String            @id @default(cuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate  @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  aquariumId         String
  aquarium           Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  status             WorkflowRunStatus  @default(ACTIVE)
  startedAt          DateTime           @default(now())
  completedAt        DateTime?
  notes              String?
  stepRuns           WorkflowStepRun[]
}

model WorkflowStepRun {
  id             String                @id @default(cuid())
  workflowRunId  String
  workflowRun    WorkflowRun           @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowStepId String
  workflowStep   WorkflowStep          @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  status         WorkflowStepRunStatus @default(PENDING)
  completedAt    DateTime?
  notes          String?
}

model AiSuggestion {
  id             String           @id @default(cuid())
  aquariumId     String?
  aquarium       Aquarium?        @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  suggestionType AiSuggestionType
  prompt         String
  response       Json
  selected       Boolean          @default(false)
  createdAt      DateTime         @default(now())
}

model QrCode {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  label      String
  payload    String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}
