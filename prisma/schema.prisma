model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  passwordHash  String?
  serverRole    ServerRole        @default(STANDARD_USER)
  sessions      Session[]
  collections   Collection[]
  collectionMemberships CollectionMembership[]
  transfers     ItemTransfer[]
  events        AquariumEvent[]
  completedCareTasks CareTask[]        @relation("CareTaskCompletedBy")
  aiRequestLogs AiRequestLog[]
  regionalStatusChecks SpeciesRegionalStatus[] @relation("RegionalStatusCheckedBy")
  aiRateLimitUsages AiRateLimitUsage[]
  aiRateLimitOverrides AiRateLimitOverride[]
  moderationReviews ModerationReview[]
  mediaAssets   MediaAsset[]       @relation("MediaUploader")
  emailLogs     EmailLog[]
  notificationPreference NotificationPreference?
  pushSubscriptions PushSubscription[]
  notificationDeliveries NotificationDelivery[]
  passwordResetTokens PasswordResetToken[]
  sentInvitations CollectionInvitation[] @relation("InvitationInviter")
  auditLogs     AuditLog[]
  generatedLabels GeneratedLabel[]
  createdHealthConditions HealthCondition[] @relation("HealthConditionCreatedBy")
  updatedHealthConditions HealthCondition[] @relation("HealthConditionUpdatedBy")
  healthConditionObservations HealthConditionObservation[]
  serverIncidents ServerIncident[] @relation("ServerIncidentCreator")
  backupRequests BackupRequest[] @relation("BackupRequester")
  restorePlans RestorePlan[] @relation("RestorePlanRequester")
  maintenanceStarts MaintenanceMode[] @relation("MaintenanceStartedBy")
  maintenanceEnds MaintenanceMode[] @relation("MaintenanceEndedBy")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lastLoginAt   DateTime?
  disabledAt    DateTime?
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String          @id @default(cuid())
  name        String
  description String?
  localityCity String?
  localityRegion String?
  localityCountry String?
  localityPostalCode String?
  localityLabel String?
  localityNotes String?
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id])
  aquariums   Aquarium[]
  aquariumEquipmentAttachments AquariumEquipmentAttachment[]
  items       AquariumItem[]
  locations   Location[]
  sources     Source[]
  lightCapabilityProfiles LightCapabilityProfile[]
  lightingSchedules LightingSchedule[]
  quarantineProjects QuarantineProject[]
  careSchedules CareSchedule[]
  events AquariumEvent[]
  medicationDefinitions MedicationDefinition[]
  medicationCourses MedicationCourse[]
  metricDefinitions MetricDefinition[]
  metricIngestionTokens MetricIngestionToken[]
  metricLatestValues MetricLatestValue[]
  grafanaManagedDashboards GrafanaManagedDashboard[]
  metricSyncLogs MetricSyncLog[]
  speciesDefinitions SpeciesDefinition[]
  speciesAliases SpeciesAlias[]
  speciesRegionalStatuses SpeciesRegionalStatus[]
  speciesHusbandryGuides SpeciesHusbandryGuide[]
  speciesHusbandryOverrides SpeciesHusbandryOverride[]
  aiRequestLogs AiRequestLog[]
  aiRateLimitUsages AiRateLimitUsage[]
  aiRateLimitOverrides AiRateLimitOverride[]
  moderationReviews ModerationReview[]
  mediaAssets   MediaAsset[]
  emailLogs     EmailLog[]
  notificationDeliveries NotificationDelivery[]
  auditLogs AuditLog[]
  qrCodes QrCode[]
  generatedLabels GeneratedLabel[]
  healthConditions HealthCondition[]
  healthConditionObservations HealthConditionObservation[]
  healthConditionLinks HealthConditionLink[]
  invitations   CollectionInvitation[]
  memberships   CollectionMembership[]
  storageEstimates StorageEstimate[]
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Location {
  id          String      @id @default(cuid())
  collectionId String
  collection  Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Location?   @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Location[]  @relation("LocationHierarchy")
  name        String
  type        LocationType @default(OTHER)
  description String?
  sortOrder   Int         @default(0)
  aquariums   Aquarium[]
  storedItems AquariumItem[] @relation("ItemStorageLocation")
  transfersFrom ItemTransfer[] @relation("TransferFromStorageLocation")
  transfersTo   ItemTransfer[] @relation("TransferToStorageLocation")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Source {
  id          String     @id @default(cuid())
  collectionId String
  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name        String
  type        SourceType @default(OTHER)
  website     String?
  notes       String?
  items       AquariumItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Aquarium {
  id                   String                  @id @default(cuid())
  collectionId         String
  collection           Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name                 String
  generatedName        String?
  slug                 String                  @unique
  description          String?
  salinity             AquariumSalinity       @default(FRESHWATER)
  aquariumType         AquariumType           @default(DISPLAY)
  volumeGallons        Float?
  volumeUnit           VolumeUnit             @default(GALLON)
  lengthInches         Float?
  widthInches          Float?
  heightInches         Float?
  location             String?
  locationId           String?
  structuredLocation   Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status               AquariumStatus          @default(ACTIVE)
  startedAt            DateTime?
  notes                String?
  coverImageUrl        String?
  coverMediaAssetId    String?                 @unique
  coverMediaAsset      MediaAsset?             @relation("AquariumCoverMedia", fields: [coverMediaAssetId], references: [id], onDelete: SetNull)
  coverCardStyle       Json?
  profile              AquariumProfile?
  items                AquariumItem[]
  transfersFrom        ItemTransfer[]          @relation("TransferFromAquarium")
  transfersTo          ItemTransfer[]          @relation("TransferToAquarium")
  events               AquariumEvent[]
  waterChangeEvents    WaterChangeEvent[]
  feedingEvents        FeedingEvent[]
  maintenanceEvents    MaintenanceEvent[]
  medicationCourses    MedicationCourse[]
  quarantineProjects   QuarantineProject[]
  readings             WaterParameterReading[]
  sensorDevices        SensorDevice[]
  workflowRuns         WorkflowRun[]
  aiSuggestions        AiSuggestion[]
  lightingAssignments  AquariumLightingAssignment[]
  equipmentAttachments AquariumEquipmentAttachment[]
  careSchedules        CareSchedule[]
  careTasks            CareTask[]
  metricConfigs        AquariumMetricConfig[]
  metricLatestValues   MetricLatestValue[]
  ingestionTokens      MetricIngestionToken[]
  grafanaDashboards    GrafanaManagedDashboard[]
  graphPanels          GraphPanel[]
  aiRequestLogs        AiRequestLog[]
  mediaAssets          MediaAsset[]            @relation("AquariumMedia")
  healthConditions     HealthCondition[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
}

model AquariumProfile {
  id                String    @id @default(cuid())
  aquariumId        String    @unique
  aquarium          Aquarium  @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  substrate         String?
  lightingType      String?
  lightingSchedule  String?
  filtration        String?
  heating           String?
  co2               String?
  waterSource       String?
  targetTemperature Float?
  targetPh          Float?
  targetGh          Float?
  targetKh          Float?
  substrateItemId   String?
  substrateItem     AquariumItem? @relation("ProfileSubstrate", fields: [substrateItemId], references: [id], onDelete: SetNull)
  lightItemId       String?
  lightItem         AquariumItem? @relation("ProfileLight", fields: [lightItemId], references: [id], onDelete: SetNull)
  heaterItemId      String?
  heaterItem        AquariumItem? @relation("ProfileHeater", fields: [heaterItemId], references: [id], onDelete: SetNull)
  notes             String?
}

model AquariumEquipmentAttachment {
  id           String                @id @default(cuid())
  collectionId String
  collection   Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId   String
  aquarium     Aquarium              @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  itemId       String
  item         AquariumItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  role         AquariumEquipmentRole
  notes        String?
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([aquariumId, itemId, role])
  @@index([collectionId, aquariumId, role, sortOrder])
  @@index([itemId])
}

model SpeciesDefinition {
  id             String          @id @default(cuid())
  collectionId   String?
  collection     Collection?     @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  category       SpeciesCategory
  commonName     String
  scientificName String?
  genus          String?
  species        String?
  variety        String?
  cultivar       String?
  notes          String?
  careNotes      String?
  lifespan       String?
  minimumGroupSize Int?
  maxHeight      Float?
  maxSpread      Float?
  growthRate     String?
  lightRequirement String?
  co2Preference  String?
  preferredHardness String?
  breedingNotes  String?
  flowRequirement String?
  tempMin        Float?
  tempMax        Float?
  phMin          Float?
  phMax          Float?
  ghMin          Float?
  ghMax          Float?
  khMin          Float?
  khMax          Float?
  salinityMin    Float?
  salinityMax    Float?
  aliases        SpeciesAlias[]
  regionalStatuses SpeciesRegionalStatus[]
  items          AquariumItem[]
  husbandryGuide SpeciesHusbandryGuide?
  husbandrySourceFor SpeciesHusbandryGuide[] @relation("SpeciesHusbandrySourceDefinition")
  husbandryOverrides SpeciesHusbandryOverride[]
  relatedEvents  AquariumEvent[]
  aiRequestLogs  AiRequestLog[]
  mediaAssets    MediaAsset[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([collectionId, category])
}

model SpeciesAlias {
  id                  String           @id @default(cuid())
  collectionId        String
  collection          Collection       @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  speciesDefinitionId String
  speciesDefinition   SpeciesDefinition @relation(fields: [speciesDefinitionId], references: [id], onDelete: Cascade)
  alias               String
  normalizedAlias     String
  aliasType           SpeciesAliasType @default(OTHER)
  notes               String?
  source              String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([collectionId, speciesDefinitionId, normalizedAlias])
  @@index([collectionId, normalizedAlias])
  @@index([speciesDefinitionId, aliasType])
}

model SpeciesRegionalStatus {
  id                         String                    @id @default(cuid())
  collectionId               String
  collection                 Collection                @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  speciesDefinitionId        String
  speciesDefinition          SpeciesDefinition         @relation(fields: [speciesDefinitionId], references: [id], onDelete: Cascade)
  localityCitySnapshot       String?
  localityRegionSnapshot     String?
  localityCountrySnapshot    String?
  localityPostalCodeSnapshot String?
  localityLabelSnapshot      String?
  status                     RegionalSpeciesStatus     @default(UNKNOWN)
  statusScope                String?
  sourceName                 String?
  sourceUrl                  String?
  notes                      String?
  confidence                 RegionalStatusConfidence?
  checkedAt                  DateTime?
  checkedByUserId            String?
  checkedByUser              User?                     @relation("RegionalStatusCheckedBy", fields: [checkedByUserId], references: [id], onDelete: SetNull)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@unique([collectionId, speciesDefinitionId])
  @@index([collectionId, status])
  @@index([speciesDefinitionId])
}

model SpeciesHusbandryGuide {
  id                        String                       @id @default(cuid())
  collectionId              String
  collection                Collection                   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  speciesDefinitionId       String                       @unique
  speciesDefinition         SpeciesDefinition            @relation(fields: [speciesDefinitionId], references: [id], onDelete: Cascade)
  sourceSpeciesDefinitionId String?
  sourceSpeciesDefinition   SpeciesDefinition?           @relation("SpeciesHusbandrySourceDefinition", fields: [sourceSpeciesDefinitionId], references: [id], onDelete: SetNull)
  status                    SpeciesHusbandryGuideStatus  @default(LOCAL)
  speciesType               SpeciesHusbandryType
  summary                   String?
  careDifficulty            String?
  sourceNotes               String?
  aiGeneratedAt             DateTime?
  aiReviewedAt              DateTime?
  fields                    Json                         @default("{}")
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@index([collectionId, status])
  @@index([sourceSpeciesDefinitionId])
}

model SpeciesHusbandryOverride {
  id                  String             @id @default(cuid())
  collectionId        String
  collection          Collection         @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumItemId      String             @unique
  aquariumItem        AquariumItem       @relation(fields: [aquariumItemId], references: [id], onDelete: Cascade)
  speciesDefinitionId String
  speciesDefinition   SpeciesDefinition  @relation(fields: [speciesDefinitionId], references: [id], onDelete: Cascade)
  overrideNotes       String?
  fields              Json               @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([collectionId])
  @@index([speciesDefinitionId])
}

model AquariumItem {
  id                  String              @id @default(cuid())
  aquariumId          String?
  aquarium            Aquarium?           @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  storageLocationId   String?
  storageLocation     Location?           @relation("ItemStorageLocation", fields: [storageLocationId], references: [id], onDelete: SetNull)
  quarantineProjectId String?
  quarantineProject   QuarantineProject?  @relation(fields: [quarantineProjectId], references: [id], onDelete: SetNull)
  collectionId        String
  collection          Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  itemType            ItemType
  speciesDefinitionId String?
  speciesDefinition   SpeciesDefinition?  @relation(fields: [speciesDefinitionId], references: [id], onDelete: SetNull)
  husbandryOverride   SpeciesHusbandryOverride?
  name                String
  description         String?
  quantity            Float               @default(1)
  unit                String?
  status              AquariumItemStatus  @default(ACTIVE)
  acquiredFrom        String?
  sourceId            String?
  source              Source?             @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  purchasePrice       Decimal?            @db.Decimal(10, 2)
  acquiredAt          DateTime?
  notes               String?
  transfers           ItemTransfer[]
  destinationTransfers ItemTransfer[]     @relation("TransferDestinationItem")
  quarantineItems     QuarantineItem[]
  equipmentProfile    EquipmentProfile?
  substrateProfiles   AquariumProfile[]   @relation("ProfileSubstrate")
  lightProfiles       AquariumProfile[]   @relation("ProfileLight")
  heaterProfiles      AquariumProfile[]   @relation("ProfileHeater")
