generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TankType {
  FRESHWATER
  BRACKISH
  SALTWATER
  POND
  QUARANTINE
  GROWOUT
  OTHER
}

enum AquariumStatus {
  ACTIVE
  PLANNING
  ARCHIVED
}

enum SpeciesCategory {
  FISH
  INVERT
  PLANT
  CORAL
  OTHER
}

enum ItemType {
  FISH
  INVERT
  PLANT
  SUBSTRATE
  HARDSCAPE
  EQUIPMENT
  BOTANICAL
  FOOD
  MEDICATION
  ADDITIVE
  OTHER
}

enum AquariumItemStatus {
  ACTIVE
  IN_AQUARIUM
  IN_STORAGE
  IN_QUARANTINE
  ARCHIVED
  CONSUMED
  DEAD
  REMOVED
  TRANSFERRED
}

enum EquipmentType {
  HEATER
  LIGHT
  FILTER
  PUMP
  AIR_PUMP
  CO2
  SENSOR
  CONTROLLER
  DOSER
  OTHER
}

enum AquariumEventType {
  NOTE
  FEEDING
  WATER_CHANGE
  TEST_RESULT
  MAINTENANCE
  MEDICATION
  LIVESTOCK_ADDITION
  LIVESTOCK_LOSS
  PLANT_ADDITION
  PLANT_REMOVAL
  EQUIPMENT_MAINTENANCE
  STOCKING
  DEATH
  SPAWN
  PHOTO
  EQUIPMENT_CHANGE
  TRANSFER
  AUDIT
  OTHER
}

enum MaintenanceType {
  WATER_CHANGE
  FILTER_SERVICE
  GLASS_CLEANING
  SUBSTRATE_VACUUM
  PLANT_TRIM
  EQUIPMENT_INSPECTION
  DOSING
  LIGHT_ADJUSTMENT
  OTHER
}

enum MedicationType {
  ANTIBIOTIC
  ANTIPARASITIC
  ANTIFUNGAL
  ANTISEPTIC
  WATER_TREATMENT
  OTHER
}

enum MedicationCourseStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum WaterParameter {
  TEMPERATURE
  PH
  CO2
  AMMONIA
  NITRITE
  NITRATE
  GH
  KH
  TDS
  TURBIDITY
  LIGHT
  WATER_LEVEL
  OTHER
}

enum ReadingSource {
  MANUAL
  SENSOR
  PROMETHEUS
  IMPORTED
}

enum MetricValueType {
  GAUGE
  COUNTER
}

enum MetricSource {
  MANUAL
  SENSOR
  API
  IMPORTED
}

enum GraphBackend {
  GRAFANA
  NATIVE
}

enum ManagedDashboardStatus {
  PENDING
  SYNCED
  FAILED
  DISABLED
}

enum MetricSyncStatus {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum SensorDeviceType {
  RASPBERRY_PI
  PICO
  ESP32
  MANUAL
  OTHER
}

enum SensorStatus {
  ACTIVE
  INACTIVE
  ERROR
  RETIRED
}

enum WorkflowCategory {
  MAINTENANCE
  QUARANTINE
  MEDICATION
  BREEDING
  CYCLING
  ACCLIMATION
  VACATION
  CUSTOM
}

enum WorkflowStepType {
  TASK
  CHECK
  INPUT
  DECISION
  WAIT
  LOG_EVENT
}

enum WorkflowRunStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

enum WorkflowStepRunStatus {
  PENDING
  COMPLETED
  SKIPPED
  BLOCKED
}

enum AiSuggestionType {
  TANK_NAME
  COVER_CARD
  CARE_ADVICE
  WORKFLOW
  STOCKING
  OTHER
}

enum CareScheduleType {
  MAINTENANCE
  FEEDING
  DOSING
  TESTING
  EQUIPMENT_SERVICE
  WATER_CHANGE
  OTHER
}

enum CareCadenceType {
  DAILY
  WEEKLY
  MONTHLY
  EVERY_N_DAYS
  CUSTOM
}

enum CareTaskStatus {
  PENDING
  COMPLETED
  SKIPPED
  OVERDUE
}

enum AiRequestType {
  TANK_NAME
  COVER_CARD
  CARE_ADVICE
  TROUBLESHOOTING
  SUMMARY
  IMAGE_GENERATION
  MODERATION
  OTHER
}

enum AiRequestStatus {
  PENDING
  SUCCEEDED
  FAILED
  BLOCKED
}

enum ModerationInputType {
  TEXT
  IMAGE
  PROMPT
}

enum ModerationStatus {
  ALLOWED
  FLAGGED
  BLOCKED
  ERROR
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum CollectionRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum LocationType {
  ROOM
  RACK
  SHELF
  STAND
  CABINET
  BIN
  DRAWER
  REFRIGERATOR
  FREEZER
  OUTDOOR_AREA
  OTHER
}

enum LightCapabilityMode {
  ON_OFF
  DIMMABLE
  RGB
  RGBW
  CUSTOM
}

enum QuarantineProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum QuarantineItemStatus {
  ACTIVE
  CLEARED
  FAILED
  TRANSFERRED
}

enum SourceType {
  STORE
  ONLINE_VENDOR
  BREEDER
  LOCAL_CLUB
  FRIEND
  IMPORTER
  SELF_PROPAGATED
  OTHER
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  passwordHash  String?
  sessions      Session[]
  collections   Collection[]
  transfers     ItemTransfer[]
  events        AquariumEvent[]
  completedCareTasks CareTask[]        @relation("CareTaskCompletedBy")
  aiRequestLogs AiRequestLog[]
  moderationReviews ModerationReview[]
  emailLogs     EmailLog[]
  passwordResetTokens PasswordResetToken[]
  sentInvitations CollectionInvitation[] @relation("InvitationInviter")
  auditLogs     AuditLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String          @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id])
  aquariums   Aquarium[]
  items       AquariumItem[]
  locations   Location[]
  sources     Source[]
  lightCapabilityProfiles LightCapabilityProfile[]
  lightingSchedules LightingSchedule[]
  quarantineProjects QuarantineProject[]
  careSchedules CareSchedule[]
  events AquariumEvent[]
  medicationDefinitions MedicationDefinition[]
  medicationCourses MedicationCourse[]
  metricDefinitions MetricDefinition[]
  metricIngestionTokens MetricIngestionToken[]
  metricLatestValues MetricLatestValue[]
  grafanaManagedDashboards GrafanaManagedDashboard[]
  metricSyncLogs MetricSyncLog[]
  aiRequestLogs AiRequestLog[]
  moderationReviews ModerationReview[]
  emailLogs     EmailLog[]
  invitations   CollectionInvitation[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Location {
  id          String      @id @default(cuid())
  collectionId String
  collection  Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Location?   @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Location[]  @relation("LocationHierarchy")
  name        String
  type        LocationType @default(OTHER)
  description String?
  sortOrder   Int         @default(0)
  aquariums   Aquarium[]
  storedItems AquariumItem[] @relation("ItemStorageLocation")
  transfersFrom ItemTransfer[] @relation("TransferFromStorageLocation")
  transfersTo   ItemTransfer[] @relation("TransferToStorageLocation")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Source {
  id          String     @id @default(cuid())
  collectionId String
  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name        String
  type        SourceType @default(OTHER)
  website     String?
  notes       String?
  items       AquariumItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Aquarium {
  id                   String                  @id @default(cuid())
  collectionId         String
  collection           Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name                 String
  generatedName        String?
  slug                 String                  @unique
  description          String?
  tankType             TankType
  volumeGallons        Float?
  lengthInches         Float?
  widthInches          Float?
  heightInches         Float?
  location             String?
  locationId           String?
  structuredLocation   Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status               AquariumStatus          @default(ACTIVE)
  startedAt            DateTime?
  notes                String?
  coverImageUrl        String?
  coverCardStyle       Json?
  profile              AquariumProfile?
  items                AquariumItem[]
  transfersFrom        ItemTransfer[]          @relation("TransferFromAquarium")
  transfersTo          ItemTransfer[]          @relation("TransferToAquarium")
  events               AquariumEvent[]
  waterChangeEvents    WaterChangeEvent[]
  feedingEvents        FeedingEvent[]
  maintenanceEvents    MaintenanceEvent[]
  medicationCourses    MedicationCourse[]
  quarantineProjects   QuarantineProject[]
  readings             WaterParameterReading[]
  sensorDevices        SensorDevice[]
  workflowRuns         WorkflowRun[]
  aiSuggestions        AiSuggestion[]
  lightingAssignments  AquariumLightingAssignment[]
  careSchedules        CareSchedule[]
  careTasks            CareTask[]
  metricConfigs        AquariumMetricConfig[]
  metricLatestValues   MetricLatestValue[]
  ingestionTokens      MetricIngestionToken[]
  grafanaDashboards    GrafanaManagedDashboard[]
  graphPanels          GraphPanel[]
  aiRequestLogs        AiRequestLog[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
}

model AquariumProfile {
  id                String    @id @default(cuid())
  aquariumId        String    @unique
  aquarium          Aquarium  @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  substrate         String?
  lightingType      String?
  lightingSchedule  String?
  filtration        String?
  heating           String?
  co2               String?
  waterSource       String?
  targetTemperature Float?
  targetPh          Float?
  targetGh          Float?
  targetKh          Float?
  substrateItemId   String?
  substrateItem     AquariumItem? @relation("ProfileSubstrate", fields: [substrateItemId], references: [id], onDelete: SetNull)
  lightItemId       String?
  lightItem         AquariumItem? @relation("ProfileLight", fields: [lightItemId], references: [id], onDelete: SetNull)
  heaterItemId      String?
  heaterItem        AquariumItem? @relation("ProfileHeater", fields: [heaterItemId], references: [id], onDelete: SetNull)
  notes             String?
}

model SpeciesDefinition {
  id             String          @id @default(cuid())
  category       SpeciesCategory
  commonName     String
  scientificName String?
  genus          String?
  species        String?
  variety        String?
  cultivar       String?
  notes          String?
  careNotes      String?
  lifespan       String?
  minimumGroupSize Int?
  maxHeight      Float?
  maxSpread      Float?
  growthRate     String?
  lightRequirement String?
  co2Preference  String?
  preferredHardness String?
  breedingNotes  String?
  flowRequirement String?
  tempMin        Float?
  tempMax        Float?
  phMin          Float?
  phMax          Float?
  ghMin          Float?
  ghMax          Float?
  khMin          Float?
  khMax          Float?
  items          AquariumItem[]
  relatedEvents  AquariumEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AquariumItem {
  id                  String              @id @default(cuid())
  aquariumId          String?
  aquarium            Aquarium?           @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  storageLocationId   String?
  storageLocation     Location?           @relation("ItemStorageLocation", fields: [storageLocationId], references: [id], onDelete: SetNull)
  quarantineProjectId String?
  quarantineProject   QuarantineProject?  @relation(fields: [quarantineProjectId], references: [id], onDelete: SetNull)
  collectionId        String
  collection          Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  itemType            ItemType
  speciesDefinitionId String?
  speciesDefinition   SpeciesDefinition?  @relation(fields: [speciesDefinitionId], references: [id], onDelete: SetNull)
  name                String
  description         String?
  quantity            Float               @default(1)
  unit                String?
  status              AquariumItemStatus  @default(ACTIVE)
  acquiredFrom        String?
  sourceId            String?
  source              Source?             @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  purchasePrice       Decimal?            @db.Decimal(10, 2)
  acquiredAt          DateTime?
  notes               String?
  transfers           ItemTransfer[]
  destinationTransfers ItemTransfer[]     @relation("TransferDestinationItem")
  quarantineItems     QuarantineItem[]
  equipmentProfile    EquipmentProfile?
  substrateProfiles   AquariumProfile[]   @relation("ProfileSubstrate")
  lightProfiles       AquariumProfile[]   @relation("ProfileLight")
  heaterProfiles      AquariumProfile[]   @relation("ProfileHeater")
  relatedEvents        AquariumEvent[]     @relation("EventRelatedItem")
  feedingEvents        FeedingEvent[]
  maintenanceEvents    MaintenanceEvent[]
  lightingAssignments  AquariumLightingAssignment[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([collectionId, status])
  @@index([aquariumId])
  @@index([storageLocationId])
  @@index([quarantineProjectId])
}

model QuarantineProject {
  id             String                  @id @default(cuid())
  collectionId   String
  collection     Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name           String
  aquariumId     String?
  aquarium       Aquarium?               @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  status         QuarantineProjectStatus @default(ACTIVE)
  startedAt      DateTime                @default(now())
  completedAt    DateTime?
  reason         String?
  notes          String?
  items          QuarantineItem[]
  inventoryItems AquariumItem[]
  transfersFrom  ItemTransfer[]          @relation("TransferFromQuarantineProject")
  transfersTo    ItemTransfer[]          @relation("TransferToQuarantineProject")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([collectionId, status])
  @@index([aquariumId])
}

model QuarantineItem {
  id                  String               @id @default(cuid())
  quarantineProjectId String
  quarantineProject   QuarantineProject    @relation(fields: [quarantineProjectId], references: [id], onDelete: Cascade)
  itemId              String
  item                AquariumItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity            Float
  status              QuarantineItemStatus @default(ACTIVE)
  startedAt           DateTime             @default(now())
  clearedAt           DateTime?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([quarantineProjectId, status])
  @@index([itemId])
}

model ItemTransfer {
  id             String     @id @default(cuid())
  itemId         String
  item           AquariumItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  destinationItemId String?
  destinationItem AquariumItem? @relation("TransferDestinationItem", fields: [destinationItemId], references: [id], onDelete: SetNull)
  fromAquariumId String?
  fromAquarium   Aquarium?  @relation("TransferFromAquarium", fields: [fromAquariumId], references: [id], onDelete: SetNull)
  toAquariumId   String?
  toAquarium     Aquarium?  @relation("TransferToAquarium", fields: [toAquariumId], references: [id], onDelete: SetNull)
  fromStorageLocationId String?
  fromStorageLocation   Location? @relation("TransferFromStorageLocation", fields: [fromStorageLocationId], references: [id], onDelete: SetNull)
  toStorageLocationId   String?
  toStorageLocation     Location? @relation("TransferToStorageLocation", fields: [toStorageLocationId], references: [id], onDelete: SetNull)
  fromQuarantineProjectId String?
  fromQuarantineProject   QuarantineProject? @relation("TransferFromQuarantineProject", fields: [fromQuarantineProjectId], references: [id], onDelete: SetNull)
  toQuarantineProjectId   String?
  toQuarantineProject     QuarantineProject? @relation("TransferToQuarantineProject", fields: [toQuarantineProjectId], references: [id], onDelete: SetNull)
  quantity       Float
  transferredAt  DateTime   @default(now())
  reason         String?
  notes          String?
  metadata       Json?
  createdById    String?
  createdBy      User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())

  @@index([itemId, transferredAt])
  @@index([destinationItemId])
}

model EquipmentProfile {
  id                      String        @id @default(cuid())
  itemId                  String        @unique
  item                    AquariumItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  equipmentType           EquipmentType
  lightCapabilityProfileId String?
  lightCapabilityProfile   LightCapabilityProfile? @relation(fields: [lightCapabilityProfileId], references: [id], onDelete: SetNull)
  brand                   String?
  model                   String?
  serialNumber            String?
  purchaseDate            DateTime?
  warrantyUntil           DateTime?
  maintenanceIntervalDays Int?
  lastMaintainedAt        DateTime?
  notes                   String?

  @@index([lightCapabilityProfileId])
}

model LightCapabilityProfile {
  id            String              @id @default(cuid())
  collectionId  String
  collection    Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  mode          LightCapabilityMode @default(DIMMABLE)
  pointCount    Int                 @default(3)
  channels      Json
  granularity   Json?
  equipmentProfiles EquipmentProfile[]
  lightingSchedules LightingSchedule[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([collectionId, name])
  @@index([collectionId, mode])
}

model AquariumEvent {
  id          String            @id @default(cuid())
  collectionId String
  collection  Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId  String
  aquarium    Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  relatedItemId String?
  relatedItem   AquariumItem?    @relation("EventRelatedItem", fields: [relatedItemId], references: [id], onDelete: SetNull)
  relatedSpeciesId String?
  relatedSpecies SpeciesDefinition? @relation(fields: [relatedSpeciesId], references: [id], onDelete: SetNull)
  relatedScheduleTaskId String?
  relatedScheduleTask CareTask?     @relation("EventRelatedScheduleTask", fields: [relatedScheduleTaskId], references: [id], onDelete: SetNull)
  relatedMedicationCourseId String?
  relatedMedicationCourse MedicationCourse? @relation("EventRelatedMedicationCourse", fields: [relatedMedicationCourseId], references: [id], onDelete: SetNull)
  eventType   AquariumEventType
  title       String
  summary     String?
  notes       String?
  maintenanceType String?
  waterChangePercent Float?
  waterChangeGallons Float?
  metadata    Json?
  eventDate   DateTime          @default(now())
  createdById String?
  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  careTasks   CareTask[]
  waterChangeEvent WaterChangeEvent?
  feedingEvent FeedingEvent?
  maintenanceEvent MaintenanceEvent?
  medicationDoseEvent MedicationDoseEvent?
  readings    WaterParameterReading[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([collectionId, eventDate])
  @@index([relatedItemId])
  @@index([relatedSpeciesId])
  @@index([relatedScheduleTaskId])
  @@index([relatedMedicationCourseId])
}

model WaterParameterReading {
  id          String          @id @default(cuid())
  aquariumId  String
  aquarium    Aquarium        @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  parameter   WaterParameter
  value       Float
  unit        String
  source      ReadingSource   @default(MANUAL)
  measuredAt  DateTime        @default(now())
  notes       String?
  aquariumEventId String?
  aquariumEvent AquariumEvent? @relation(fields: [aquariumEventId], references: [id], onDelete: SetNull)

  @@index([aquariumEventId])
}

model WaterChangeEvent {
  id                 String        @id @default(cuid())
  aquariumEventId    String        @unique
  aquariumEvent      AquariumEvent @relation(fields: [aquariumEventId], references: [id], onDelete: Cascade)
  aquariumId         String
  aquarium           Aquarium      @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  volumeGallons      Float?
  percentChanged     Float?
  waterSource        String?
  conditionerUsed    String?
  temperatureMatched Boolean?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([aquariumId])
}

model FeedingEvent {
  id               String        @id @default(cuid())
  aquariumEventId  String        @unique
  aquariumEvent    AquariumEvent @relation(fields: [aquariumEventId], references: [id], onDelete: Cascade)
  aquariumId       String
  aquarium         Aquarium      @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  foodItemId       String?
  foodItem         AquariumItem? @relation(fields: [foodItemId], references: [id], onDelete: SetNull)
  foodNameSnapshot String?
  amount           String?
  target           String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([aquariumId])
  @@index([foodItemId])
}

model MaintenanceEvent {
  id               String          @id @default(cuid())
  aquariumEventId  String          @unique
  aquariumEvent    AquariumEvent   @relation(fields: [aquariumEventId], references: [id], onDelete: Cascade)
  aquariumId       String
  aquarium         Aquarium        @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  maintenanceType  MaintenanceType
  equipmentItemId  String?
  equipmentItem    AquariumItem?   @relation(fields: [equipmentItemId], references: [id], onDelete: SetNull)
  summary          String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([aquariumId])
  @@index([equipmentItemId])
}

model MedicationDefinition {
  id                 String              @id @default(cuid())
  collectionId       String
  collection         Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name               String
  manufacturer       String?
  medicationType     MedicationType      @default(OTHER)
  activeIngredients  String?
  concentration      String?
  defaultDoseAmount  Float?
  defaultDoseUnit    String?
  dosePerGallons     Float?
  scheduleNotes      String?
  safetyNotes        String?
  contraindications  String?
  courses            MedicationCourse[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([collectionId, name])
}

model MedicationCourse {
  id                     String                 @id @default(cuid())
  collectionId           String
  collection             Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId             String
  aquarium               Aquarium               @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  medicationDefinitionId String
  medicationDefinition   MedicationDefinition   @relation(fields: [medicationDefinitionId], references: [id], onDelete: Restrict)
  title                  String
  reason                 String?
  tankVolumeGallons      Float
  calculatedDoseAmount   Float?
  calculatedDoseUnit     String?
  doseSchedule           Json?
  status                 MedicationCourseStatus @default(ACTIVE)
  startedAt              DateTime               @default(now())
  completedAt            DateTime?
  notes                  String?
  events                 AquariumEvent[]        @relation("EventRelatedMedicationCourse")
  doseEvents             MedicationDoseEvent[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([collectionId, status])
  @@index([aquariumId, status])
}

model MedicationDoseEvent {
  id                 String           @id @default(cuid())
  aquariumEventId    String           @unique
  aquariumEvent      AquariumEvent    @relation(fields: [aquariumEventId], references: [id], onDelete: Cascade)
  medicationCourseId String
  medicationCourse   MedicationCourse @relation(fields: [medicationCourseId], references: [id], onDelete: Cascade)
  doseAmount         Float?
  doseUnit           String?
  doseNumber         Int?
  dosedAt            DateTime         @default(now())
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([medicationCourseId])
}

model MetricDefinition {
  id               String                  @id @default(cuid())
  collectionId     String
  collection       Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  key              String
  displayName      String
  description      String?
  parameter        WaterParameter?
  unit             String
  prometheusName   String
  valueType        MetricValueType         @default(GAUGE)
  defaultMin       Float?
  defaultMax       Float?
  enabledByDefault Boolean                 @default(true)
  configs          AquariumMetricConfig[]
  latestValues     MetricLatestValue[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([collectionId, key])
  @@index([collectionId, enabledByDefault])
}

model AquariumMetricConfig {
  id                String             @id @default(cuid())
  collectionId      String
  aquariumId        String
  aquarium          Aquarium           @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  metricDefinitionId String
  metricDefinition  MetricDefinition   @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  enabled           Boolean            @default(true)
  minValue          Float?
  maxValue          Float?
  displayOrder      Int                @default(0)
  source            MetricSource       @default(MANUAL)
  latestValue       MetricLatestValue?
  graphPanels       GraphPanel[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([aquariumId, metricDefinitionId])
  @@index([collectionId, enabled])
  @@index([metricDefinitionId])
}

model MetricLatestValue {
  id                String               @id @default(cuid())
  collectionId      String
  collection        Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId        String
  aquarium          Aquarium             @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  metricDefinitionId String
  metricDefinition  MetricDefinition     @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  metricConfigId    String               @unique
  metricConfig      AquariumMetricConfig @relation(fields: [metricConfigId], references: [id], onDelete: Cascade)
  value             Float
  unit              String
  source            MetricSource         @default(API)
  deviceId          String?
  sensorChannelId   String?
  measuredAt        DateTime
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([collectionId, aquariumId])
  @@index([metricDefinitionId])
  @@index([measuredAt])
}

model MetricIngestionToken {
  id           String      @id @default(cuid())
  collectionId String
  collection   Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId   String?
  aquarium     Aquarium?   @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  name         String
  tokenHash    String      @unique
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([collectionId, aquariumId])
  @@index([revokedAt])
}

model GrafanaManagedDashboard {
  id           String                 @id @default(cuid())
  collectionId String
  collection   Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId   String
  aquarium     Aquarium               @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  uid          String                 @unique
  title        String
  folderUid    String?
  status       ManagedDashboardStatus @default(PENDING)
  lastSyncedAt DateTime?
  lastError    String?
  panels       GraphPanel[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([aquariumId])
  @@index([collectionId, status])
}

model GraphPanel {
  id             String                  @id @default(cuid())
  collectionId   String
  aquariumId     String
  aquarium       Aquarium                @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  metricConfigId String
  metricConfig   AquariumMetricConfig    @relation(fields: [metricConfigId], references: [id], onDelete: Cascade)
  dashboardId    String?
  dashboard      GrafanaManagedDashboard? @relation(fields: [dashboardId], references: [id], onDelete: SetNull)
  backend        GraphBackend             @default(GRAFANA)
  panelId        Int?
  title          String
  embedPath      String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([metricConfigId, backend])
  @@index([collectionId, aquariumId])
  @@index([dashboardId])
}

model MetricSyncLog {
  id           String           @id @default(cuid())
  collectionId String?
  collection   Collection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  aquariumId   String?
  action       String
  status       MetricSyncStatus
  message      String?
  metadata     Json?
  createdAt    DateTime         @default(now())

  @@index([collectionId, createdAt])
  @@index([aquariumId, createdAt])
  @@index([status, createdAt])
}

model CareSchedule {
  id           String            @id @default(cuid())
  collectionId String
  collection   Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  aquariumId   String?
  aquarium     Aquarium?         @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  scheduleType CareScheduleType
  cadenceType  CareCadenceType
  intervalDays Int?
  daysOfWeek   Json?
  dayOfMonth   Int?
  startDate    DateTime
  endDate      DateTime?
  nextDueAt    DateTime?
  enabled      Boolean           @default(true)
  tasks        CareTask[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([collectionId, enabled, nextDueAt])
  @@index([aquariumId])
}

model CareTask {
  id             String         @id @default(cuid())
  careScheduleId String
  careSchedule   CareSchedule   @relation(fields: [careScheduleId], references: [id], onDelete: Cascade)
  aquariumId     String?
  aquarium       Aquarium?      @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  dueAt          DateTime
  completedAt    DateTime?
  skippedAt      DateTime?
  status         CareTaskStatus @default(PENDING)
  completedById  String?
  completedBy    User?          @relation("CareTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  relatedEventId String?
  relatedEvent   AquariumEvent? @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  timelineEvents AquariumEvent[] @relation("EventRelatedScheduleTask")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([aquariumId, status, dueAt])
  @@index([careScheduleId, status, dueAt])
  @@index([completedById])
  @@index([relatedEventId])
}

model LightingSchedule {
  id          String                  @id @default(cuid())
  collectionId String
  collection  Collection              @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  capabilityProfileId String?
  capabilityProfile   LightCapabilityProfile? @relation(fields: [capabilityProfileId], references: [id], onDelete: SetNull)
  name        String
  description String?
  points      LightingSchedulePoint[]
  assignments AquariumLightingAssignment[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([collectionId, name])
  @@index([capabilityProfileId])
}

model LightingSchedulePoint {
  id          String           @id @default(cuid())
  scheduleId  String
  schedule    LightingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  timeOfDay   String
  white       Int
  red         Int
  green       Int
  blue        Int
  warmWhite   Int?
  intensity   Int?
  values      Json?
  sortOrder   Int              @default(0)

  @@index([scheduleId, sortOrder])
}

model AquariumLightingAssignment {
  id              String            @id @default(cuid())
  aquariumId      String
  aquarium        Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  equipmentItemId String?
  equipmentItem   AquariumItem?     @relation(fields: [equipmentItemId], references: [id], onDelete: SetNull)
  scheduleId      String?
  schedule        LightingSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([aquariumId, equipmentItemId])
  @@index([aquariumId])
  @@index([equipmentItemId])
  @@index([scheduleId])
}

model SensorDevice {
  id             String            @id @default(cuid())
  aquariumId     String?
  aquarium       Aquarium?         @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  name           String
  deviceType     SensorDeviceType
  status         SensorStatus       @default(ACTIVE)
  prometheusJob  String?
  notes          String?
  channels       SensorChannel[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model SensorChannel {
  id                   String          @id @default(cuid())
  sensorDeviceId       String
  sensorDevice         SensorDevice    @relation(fields: [sensorDeviceId], references: [id], onDelete: Cascade)
  parameter            WaterParameter
  displayName          String
  unit                 String
  prometheusMetricName String?
  enabled              Boolean         @default(true)
}

model WorkflowTemplate {
  id          String             @id @default(cuid())
  name        String
  description String?
  category    WorkflowCategory
  isSystem    Boolean            @default(false)
  steps       WorkflowStep[]
  runs        WorkflowRun[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model WorkflowStep {
  id                 String           @id @default(cuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  title              String
  description        String?
  stepType           WorkflowStepType
  config             Json?
  runs               WorkflowStepRun[]
}

model WorkflowRun {
  id                 String            @id @default(cuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate  @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  aquariumId         String
  aquarium           Aquarium          @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  status             WorkflowRunStatus  @default(ACTIVE)
  startedAt          DateTime           @default(now())
  completedAt        DateTime?
  notes              String?
  stepRuns           WorkflowStepRun[]
}

model WorkflowStepRun {
  id             String                @id @default(cuid())
  workflowRunId  String
  workflowRun    WorkflowRun           @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowStepId String
  workflowStep   WorkflowStep          @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  status         WorkflowStepRunStatus @default(PENDING)
  completedAt    DateTime?
  notes          String?
}

model AiSuggestion {
  id             String           @id @default(cuid())
  aquariumId     String?
  aquarium       Aquarium?        @relation(fields: [aquariumId], references: [id], onDelete: Cascade)
  suggestionType AiSuggestionType
  prompt         String
  response       Json
  selected       Boolean          @default(false)
  createdAt      DateTime         @default(now())
}

model AiRequestLog {
  id            String          @id @default(cuid())
  collectionId  String?
  collection    Collection?     @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  aquariumId    String?
  aquarium      Aquarium?       @relation(fields: [aquariumId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestType   AiRequestType
  provider      String
  model         String?
  promptSummary String?
  status        AiRequestStatus @default(PENDING)
  input         Json?
  output        Json?
  error         String?
  tokensInput   Int?
  tokensOutput  Int?
  costEstimate  Decimal?        @db.Decimal(12, 6)
  createdAt     DateTime        @default(now())
  completedAt   DateTime?

  @@index([collectionId, createdAt])
  @@index([aquariumId, createdAt])
  @@index([userId, createdAt])
}

model ModerationReview {
  id           String              @id @default(cuid())
  collectionId String?
  collection   Collection?         @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  userId       String?
